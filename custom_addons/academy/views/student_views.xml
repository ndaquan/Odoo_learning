<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ==================== LIST VIEW (DANH SÁCH SINH VIÊN) ==================== -->
    <record id="academy.student_tree" model="ir.ui.view">
        <field name="name">academy.student.tree</field>
        <field name="model">academy.student</field>
        <field name="arch" type="xml">
            <list string="Danh sách sinh viên">
                <field name="name"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="birth_date"/>
                <field name="course_id"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- ==================== FORM VIEW (CHI TIẾT SINH VIÊN) ==================== -->
    <record id="academy.student_form" model="ir.ui.view">
        <field name="name">academy.student.form</field>
        <field name="model">academy.student</field>
        <field name="arch" type="xml">
            <form string="Sinh viên">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="email"/>
                        <field name="phone"/>
                        <field name="birth_date"/>
                        <field name="course_id"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

</odoo>