<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ==================== LIST VIEW (DANH SÁCH) ==================== -->
    <record id="academy.course_tree" model="ir.ui.view">
        <field name="name">academy.course.tree</field>
        <field name="model">academy.course</field>
        <field name="arch" type="xml">
            <list string="Danh sách khóa học">
                <field name="name"/>
                <field name="start_date"/>
                <field name="duration"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- ==================== FORM VIEW (CHI TIẾT) ==================== -->
    <record id="academy.course_form" model="ir.ui.view">
        <field name="name">academy.course.form</field>
        <field name="model">academy.course</field>
        <field name="arch" type="xml">
            <form string="Khóa học">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="start_date"/>
                        <field name="duration"/>
                        <field name="active"/>
                    </group>

                    <notebook>
                        <page string="Mô tả">
                            <field name="description"/>
                        </page>

                        <page string="Sinh viên">
                            <field name="student_ids" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form> 
        </field>
    </record>

</odoo>