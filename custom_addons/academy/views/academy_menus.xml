<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ==================== MENU CHÍNH ==================== -->
    <menuitem   
        id="academy_menu_root"
        name="Academy"
        sequence="10" />
    
    <!-- ==================== ACTION + MENU CHO KHÓA HỌC ==================== -->
    <record id="action_course" model="ir.actions.act_window">
        <field name="name">Khóa học</field>
        <field name="res_model">academy.course</field> 
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_course"
        parent="academy_menu_root"
        name="Khóa học"
        action="action_course"
        sequence="10" />
 
    <!-- ==================== ACTION + MENU CHO SINH VIÊN ==================== -->
    <record id="action_student" model="ir.actions.act_window">
        <field name="name">Sinh viên</field>
        <field name="res_model">academy.student</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem 
        id="menu_student"
        parent="academy_menu_root"
        name="Sinh viên"
        action="action_student"
        sequence="10" />

</odoo>