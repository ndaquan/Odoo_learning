<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <record id="view_shopify_config_tree" model="ir.ui.view">
    <field name="name">shopify.integration.config.tree</field>
    <field name="model">shopify.integration.config</field>
    <field name="arch" type="xml">
      <list>
        <field name="name"/>
        <field name="shop_url"/>
        <field name="warehouse_id"/>
        <field name="last_sync"/>
      </list>
    </field>
  </record>

  <record id="view_shopify_config_form" model="ir.ui.view">
    <field name="name">shopify.integration.config.form</field>
    <field name="model">shopify.integration.config</field>
    <field name="arch" type="xml">
      <form string="Shopify Configuration">
        <header>
          <button name="action_test_connection" type="object" string="Test Connection" class="btn-primary"/>
        </header>
        <sheet>
          <group>
            <field name="name"/>
            <field name="shop_url"/>
            <field name="warehouse_id"/>
            <field name="last_sync" readonly="1"/>
          </group>
          <group string="Credentials">
            <field name="client_id"/>
            <field name="client_secret" password="True"/>
            <field name="access_token" password="True" readonly="1"/>
            <field name="access_token_expires_at" readonly="1"/>
            <field name="api_version"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <record id="action_shopify_config" model="ir.actions.act_window">
    <field name="name">Shopify Configurations</field>
    <field name="res_model">shopify.integration.config</field>
    <field name="view_mode">list,form</field>
  </record>
</odoo>