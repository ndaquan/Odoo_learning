<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <record id="view_shopify_sync_log_tree" model="ir.ui.view">
    <field name="name">shopify.sync.log.tree</field>
    <field name="model">shopify.sync.log</field>
    <field name="arch" type="xml">
      <list>
        <field name="create_date"/>
        <field name="config_id"/>
        <field name="sync_type"/>
        <field name="status"/>
        <field name="operation_ref" optional="show"/>
        <field name="shopify_id"/>
        <field name="message" optional="show"/>
      </list>
    </field>
  </record>

  <record id="view_shopify_sync_log_search" model="ir.ui.view">
    <field name="name">shopify.sync.log.search</field>
    <field name="model">shopify.sync.log</field>
    <field name="arch" type="xml">
      <search>
        <field name="config_id"/>
        <field name="sync_type"/>
        <field name="status"/>
        <field name="shopify_id"/>
        <field name="operation_ref"/>


        <filter string="Success" name="status_success" domain="[('status','=','success')]"/>
        <filter string="Partial" name="status_partial" domain="[('status','=','partial')]"/>
        <filter string="Failed" name="status_failed" domain="[('status','=','failed')]"/>


        <filter string="Products" name="type_product" domain="[('sync_type','=','product')]"/>
        <filter string="Inventory" name="type_inventory" domain="[('sync_type','=','inventory')]"/>
        <filter string="Orders" name="type_order" domain="[('sync_type','=','order')]"/>
        <filter string="Test" name="type_test" domain="[('sync_type','=','test')]"/>


        <filter string="Store" name="group_config" context="{'group_by':'config_id'}"/>
        <filter string="Type" name="group_type" context="{'group_by':'sync_type'}"/>
        <filter string="Status" name="group_status" context="{'group_by':'status'}"/>
      </search>
    </field>
  </record>

  <record id="action_shopify_sync_log" model="ir.actions.act_window">
    <field name="name">Shopify Sync Logs</field>
    <field name="res_model">shopify.sync.log</field>
    <field name="view_mode">list,form</field>
    <field name="search_view_id" ref="view_shopify_sync_log_search"/>
    <field name="help" type="html">
      <p class="o_view_nocontent_smiling_face">
        No sync logs yet.
      </p>
      <p>Run a manual sync or wait for scheduled actions.</p>
    </field>
  </record>
</odoo>